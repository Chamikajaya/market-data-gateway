#!/usr/bin/env bash

# Commit-msg hook: enforces Conventional-Commits

# fail fast
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'  # no color

# Git passes the path to the temporary commit message file as $1
COMMIT_MSG_FILE="$1"
# Extract only the first line (the subject line) of the commit message
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

# Allow merge commits - Bypass validation for Git's auto-generated merge commits
if echo "$COMMIT_MSG" | grep -qE "^Merge "; then
    exit 0
fi

# Conventional Commits pattern:
#   type(scope): description   OR   type: description
#   Optionally with a ! before the colon for breaking changes
PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?!?: .{1,}"

# Validate the subject line against the regex pattern
if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo -e "${RED}✗ Invalid commit message format!${NC}"
    echo ""
    echo -e "  Your message: ${YELLOW}${COMMIT_MSG}${NC}"
    echo ""
    echo -e "  Expected format: ${GREEN}<type>(<scope>): <description>${NC}"
    echo -e "               or: ${GREEN}<type>: <description>${NC}"
    echo ""
    echo "  Allowed types:"
    echo "    feat, fix, docs, style, refactor, perf,"
    echo "    test, build, ci, chore, revert"
    echo ""
    echo "  Examples:"
    echo "    feat(auth): add login endpoint"
    echo "    fix: resolve null pointer in user service"
    echo "    docs: update API documentation"
    echo "    chore!: drop support for Go 1.20"
    echo ""
    exit 1
fi

echo -e "${GREEN}✓ Commit message follows Conventional Commits format${NC}"
exit 0