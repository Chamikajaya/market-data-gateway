#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running lint checks...${NC}"

if ! command -v golangci-lint >/dev/null 2>&1; then
  echo -e "${RED}golangci-lint is not installed or not in PATH.${NC}"
  exit 1
fi

if [ ! -f "go.mod" ]; then
  echo -e "${RED}go.mod not found at repo root. Is this a Go module?${NC}"
  exit 1
fi

if golangci-lint run ./...; then
  echo -e "\n${GREEN}All lint checks passed!${NC}"
  exit 0
else
  echo -e "\n${RED}Commit aborted: lint errors found. Fix them and try again.${NC}"
  exit 1
fi